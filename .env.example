# MongoDB configuration
# Local execution:
# MONGO_URI=mongodb://localhost:27017/
#
# Docker execution:
# MONGO_URI=mongodb://mongo:27017/
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=music_archive

# Flask configuration
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=true

# Replace this value in your local .env file
FLASK_SECRET_KEY=change_me_with_a_random_secret_key

# Spotify configuration
# Optional: used to enable full Spotify metadata retrieval.
# If left empty or unavailable, the app falls back to Spotify oEmbed and manual completion.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=